# Directories

POSIXLIB = dh2:SDK/PosixLib
NETINCLUDE = dh2:SDK/NDK32/SANA+RoadshowTCP-IP/netinclude
AMISSL = dh2:SDK/AmiSSL/Developer
LIBDIRS = -L$(AMISSL)/lib/AmigaOS3 -L$(POSIXLIB)/AmigaOS3
INCLUDEDIRS = -I$(NETINCLUDE) -I$(AMISSL)/include -I$(POSIXLIB)/include -I$(NDK_INC)


# Compiler options

CCBIN = vc
CCOPTS = -c99
CPU = 68000
FPU = soft
LIBS = -lposix -lamiga -lauto
MATHLIB = -lmsoft

CC = $(CCBIN) $(CCOPTS) -cpu=$(CPU) -fpu=$(FPU) $(INCLUDEDIRS) $(LIBDIRS) $(LIBS)

# Target directories

BUILDDIR = build-vbcc
DISTDIR = $(BUILDDIR)/$(CPU)-$(FPU)
OBJDIR = $(BUILDDIR)/$(CPU)-$(FPU)/obj
TESTBINDIR = $(BUILDDIR)/$(CPU)-$(FPU)/tests


# Make rules

.PHONY: all clean prepare

all: shelltools tests scripts

prepare:
	makedir $(BUILDDIR)
	makedir $(DISTDIR)
	makedir $(OBJDIR)
	makedir $(TESTBINDIR)

clean:
	delete all $(BUILDDIR)

shelltools: arch cldir fetch img2ascii mktemp shprintf shresetcolor shsetcolor

tests: archivetest filetoolstest shelltest

scripts: prepare
	cp src/ShellScripts/*.shell $(TESTBINDIR)

APPSUPPORTSRCS=$(wildcard src/AppSupport/*.c)
APPSUPPORTOBJS=$(APPSUPPORTSRCS:src/AppSupport/%.c=$(OBJDIR)/.o%)

%.o: src/AppSupport/%.c src/AppSupport/%.h
	$(CC) -c -o $(OBJDIR)/$@ $<


# Shell tools

arch: prepare src/Shelltools/arch.c archive.o collections.o
	$(CC) src/Shelltools/arch.c $(OBJDIR)/archive.o $(OBJDIR)/collections.o -o $(DISTDIR)/arch

cldir: prepare src/Shelltools/cldir.c shell.o environment.o
	$(CC) src/Shelltools/cldir.c $(OBJDIR)/shell.o $(OBJDIR)/environment.o -o $(DISTDIR)/cldir

fetch: prepare src/Shelltools/fetch.c network.o collections.o
	$(CC) src/Shelltools/fetch.c $(OBJDIR)/network.o $(OBJDIR)/collections.o -o $(DISTDIR)/fetch

img2ascii: prepare src/Shelltools/img2ascii.c image.o environment.o shell.o
	$(CC) ${MATHLIB} src/Shelltools/img2ascii.c $(OBJDIR)/image.o $(OBJDIR)/environment.o $(OBJDIR)/shell.o -o $(DISTDIR)/img2ascii

mktemp: prepare src/Shelltools/mktemp.c filetools.o collections.o
	$(CC) src/Shelltools/mktemp.c $(OBJDIR)/filetools.o $(OBJDIR)/collections.o -o ${DISTDIR}/mktemp

shprintf: prepare src/Shelltools/shprintf.c shell.o environment.o
	$(CC) src/Shelltools/shprintf.c $(OBJDIR)/shell.o $(OBJDIR)/environment.o  -o $(DISTDIR)/shprintf

shresetcolor: prepare src/Shelltools/shresetcolor.c shell.o environment.o
	$(CC) src/Shelltools/shresetcolor.c $(OBJDIR)/shell.o $(OBJDIR)/environment.o -o $(DISTDIR)/shresetcolor

shsetcolor: prepare src/Shelltools/shsetcolor.c shell.o environment.o
	$(CC) src/Shelltools/shsetcolor.c $(OBJDIR)/shell.o $(OBJDIR)/environment.o -o $(DISTDIR)/shsetcolor


# App support tests

archivetest: prepare src/AppSupportTests/archivetest.c archive.o collections.o testutils.o shell.o environment.o
	$(CC) src/AppSupportTests/archivetest.c $(OBJDIR)/archive.o $(OBJDIR)/collections.o $(OBJDIR)/testutils.o $(OBJDIR)/shell.o $(OBJDIR)/environment.o -o $(TESTBINDIR)/archivetest

filetoolstest: prepare src/AppSupportTests/filetoolstest.c filetools.o testutils.o shell.o environment.o collections.o
	$(CC) src/AppSupportTests/filetoolstest.c $(OBJDIR)/filetools.o $(OBJDIR)/testutils.o $(OBJDIR)/shell.o $(OBJDIR)/environment.o $(OBJDIR)/collections.o -o $(TESTBINDIR)/filetoolstest

shelltest: prepare src/AppSupportTests/shelltest.c environment.o shell.o collections.o filetools.o
	$(CC) src/AppSupportTests/shelltest.c $(OBJDIR)/environment.o $(OBJDIR)/shell.o $(OBJDIR)/collections.o $(OBJDIR)/filetools.o -o $(TESTBINDIR)/shelltest
